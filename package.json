{
  "name": "@speajus/markdown-to-pdf",
  "version": "1.0.5",
  "description": "A new project created with Intent by Augment.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "markdown-to-pdf": "dist/cli.js"
  },
  "exports": {
    "node": {
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "browser": {
      "require": "./dist/browser.js",
      "import": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/fonts && cp src/fonts/* dist/fonts/",
    "generate": "tsx samples/generate.ts",
    "test": "tsx samples/generate.ts"
  },
  "keywords": [
    "markdown",
    "pdf",
    "converter"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/speajus/markdown-to-pdf"
  },
  "type": "commonjs",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "marked": "^17.0.2",
    "pdfkit": "^0.17.2",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/pdfkit": "^0.17.5",
    "@types/prismjs": "^1.26.6",
    "canvas": "^3.2.1",
    "pdfjs-dist": "^3.11.174",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "canvas": "^3.2.1"
    }
  }
