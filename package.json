{
  "name": "@speajus/markdown-to-pdf",
  "version": "1.0.14",
  "description": "A new project created with Intent by Augment.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "markdown-to-pdf": "dist/cli.js"
  },
  "exports": {
    "node": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "browser": {
      "types": "./dist/browser.d.ts",
      "require": "./dist/browser.js",
      "import": "./dist/browser.js"
    },
    "default": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),p=require('path'),d=p.join('node_modules','pdfkit','js');if(!fs.existsSync(d)){const{execSync:e}=require('child_process');e('cd node_modules/pdfkit && corepack yarn install && corepack yarn build',{stdio:'inherit'})}\"",
    "docs:dev": "cd docs && $npm_execpath dev",
    "build": "tsc && mkdir -p dist/fonts && cp src/fonts/* dist/fonts/",
    "generate": "tsx samples/generate.ts",
    "readme": "pnpm tsx ./src/cli.ts README.md README.pdf",
    "test": "tsx --test test/*.test.ts && tsx samples/generate.ts && pnpm run readme"
  },
  "keywords": [
    "markdown",
    "pdf",
    "converter"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/speajus/markdown-to-pdf.git"
  },
  "type": "commonjs",
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "marked": "^17.0.2",
    "pdfkit": "github:jspears/pdfkit#support-color-emoji-google",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/pdfkit": "^0.17.5",
    "@types/prismjs": "^1.26.6",
    "canvas": "^3.2.1",
    "pdfjs-dist": "^3.11.174",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "canvas": "^3.2.1"
    }
  },
  "packageManager": "pnpm@9.2.0+sha512.98a80fd11c2e7096747762304106432b3ddc67dcf54b5a8c01c93f68a2cd5e05e6821849522a06fb76284d41a2660d5e334f2ee3bbf29183bf2e739b1dafa771"
}
